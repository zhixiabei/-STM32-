#ifndef __SECRET_H
#define __SECRET_H

/* ============================================================
 * secret.h.example —— 凭据模板
 * 1. 复制此文件为 secret.h
 * 2. 填入你自己的 WiFi 和 OneNET 凭据
 * 3. secret.h 已被 .gitignore 排除，不会提交到 Git
 * ============================================================ */

/* WiFi */
#define WIFI_SSID       "YOUR_WIFI_SSID"
#define WIFI_PASSWORD   "YOUR_WIFI_PASSWORD"

/* OneNET MQTT */
#define ONENET_PRODUCT_ID   "YOUR_PRODUCT_ID"
#define ONENET_DEVICE_NAME  "YOUR_DEVICE_NAME"
#define ONENET_MQTT_PASS    "YOUR_MQTT_PASSWORD_TOKEN"

#endif /* __SECRET_H */
